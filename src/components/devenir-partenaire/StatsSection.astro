---
const stats = [
  { value: 3, label: "Pilotes", note: "engagés en Championnat de France", isNumber: true },
  { value: 6, label: "Manches", note: "sur la saison 2026", isNumber: true },
  { value: 5, label: "Partenaires", note: "actuels", isNumber: true },
  { value: "Nouvelle-Aquitaine", label: "Territoire", note: "d'ancrage", isNumber: false },
];
---

<section class="dp-stats relative bg-swsm-black text-swsm-white py-24 md:py-32 px-6 md:px-10 overflow-hidden" style="z-index:3;box-shadow:0 -30px 60px -10px rgba(0,0,0,0.4);">
  <div class="absolute inset-0 pointer-events-none opacity-30" aria-hidden="true"
    style="background: radial-gradient(ellipse at 30% 50%, rgba(236,45,124,0.15) 0%, transparent 55%), radial-gradient(ellipse at 70% 60%, rgba(91,33,182,0.15) 0%, transparent 55%);"></div>

  <div class="relative z-10 max-w-[1240px] mx-auto">
    <header class="mb-16 md:mb-20 max-w-2xl">
      <p class="dp-stats-eyebrow text-xs uppercase tracking-eyebrow font-display font-medium text-swsm-pink mb-5">
        La structure en chiffres
      </p>
      <h2
        class="dp-stats-title font-display font-bold text-swsm-white tracking-caps-tight leading-[1.05] text-3xl md:text-5xl"
        data-split-mask
      >
        Une visibilité qui se construit.
      </h2>
    </header>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-10 md:gap-12">
      {stats.map((stat) => (
        <div class="dp-stat">
          {stat.isNumber ? (
            <p
              class="dp-stat-value font-display font-bold text-swsm-white tracking-caps-tight leading-none text-6xl md:text-7xl lg:text-[6rem]"
              data-count-up={stat.value}
            >0</p>
          ) : (
            <p class="dp-stat-value font-display font-bold text-swsm-white tracking-caps-tight leading-[0.95] text-2xl md:text-3xl lg:text-4xl">
              {stat.value}
            </p>
          )}
          <p class="font-display font-medium text-sm uppercase tracking-caps-loose text-swsm-pink mt-3 md:mt-4">
            {stat.label}
          </p>
          <p class="font-body text-xs md:text-sm text-swsm-white/60 mt-1">
            {stat.note}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const section = document.querySelector<HTMLElement>(".dp-stats");
  const eyebrow = document.querySelector<HTMLElement>(".dp-stats-eyebrow");
  const stats = Array.from(document.querySelectorAll<HTMLElement>(".dp-stat"));
  const counters = Array.from(document.querySelectorAll<HTMLElement>("[data-count-up]"));

  if (section && eyebrow && stats.length) {
    if (reduce) {
      gsap.set([eyebrow, ...stats], { opacity: 1, y: 0 });
      counters.forEach((el) => {
        const target = parseFloat(el.dataset.countUp || "0");
        el.textContent = String(target);
      });
    } else {
      gsap.set(eyebrow, { opacity: 0, y: 20 });
      gsap.set(stats, { opacity: 0, y: 30 });

      const tl = gsap.timeline({
        scrollTrigger: { trigger: section, start: "top 70%", toggleActions: "play none none none" },
      });
      tl.to(eyebrow, { opacity: 1, y: 0, duration: 0.5, ease: "power2.out" })
        .to(stats, { opacity: 1, y: 0, duration: 0.6, ease: "power2.out", stagger: 0.15 }, "-=0.2");

      // Count-up : anime de 0 à la valeur cible en 1.5s
      counters.forEach((el) => {
        const target = parseFloat(el.dataset.countUp || "0");
        const counter = { value: 0 };
        gsap.to(counter, {
          value: target,
          duration: 1.5,
          ease: "power2.out",
          onUpdate: () => { el.textContent = String(Math.round(counter.value)); },
          scrollTrigger: { trigger: el, start: "top 80%", toggleActions: "play none none none" },
        });
      });
    }
  }
</script>
