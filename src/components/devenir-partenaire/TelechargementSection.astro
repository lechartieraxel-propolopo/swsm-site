---
---

<section class="dp-dl relative bg-gradient-signature text-swsm-white py-24 md:py-32 px-6 md:px-10 overflow-hidden" style="z-index:8;box-shadow:0 -30px 60px -10px rgba(0,0,0,0.45);">
  <div class="absolute inset-0 pointer-events-none opacity-30" aria-hidden="true"
    style="background: radial-gradient(circle at 20% 50%, rgba(255,255,255,0.15) 0%, transparent 50%), radial-gradient(circle at 80% 50%, rgba(255,255,255,0.12) 0%, transparent 50%);"></div>

  <div class="relative z-10 max-w-[1240px] mx-auto grid md:grid-cols-2 gap-12 md:gap-16">
    <div class="dp-dl-block flex flex-col gap-5">
      <p class="text-xs uppercase tracking-eyebrow font-display font-medium text-swsm-white/85">
        Le dossier
      </p>
      <h2 class="font-display font-bold text-swsm-white tracking-caps-tight leading-[1.1] text-2xl md:text-4xl">
        Téléchargez le dossier sponsoring complet.
      </h2>
      <p class="font-body text-base text-swsm-white/85 leading-relaxed">
        Présentation détaillée des niveaux, contreparties, calendrier et grille tarifaire.
      </p>
      <a
        href="/dossier-sponsoring.pdf"
        download
        id="dp-dl-button"
        class="btn-cta btn-cta-light font-display font-bold text-sm uppercase tracking-caps-loose px-7 py-4 mt-4 self-start"
      >
        <span>Télécharger le PDF</span>
        <span class="btn-cta-arrow">→</span>
      </a>
    </div>

    <div class="dp-dl-block flex flex-col gap-5 md:border-l md:border-swsm-white/20 md:pl-12 lg:pl-16">
      <p class="text-xs uppercase tracking-eyebrow font-display font-medium text-swsm-white/85">
        Ou direct
      </p>
      <h2 class="font-display font-bold text-swsm-white tracking-caps-tight leading-[1.1] text-2xl md:text-4xl">
        Prenez RDV en direct.
      </h2>
      <p class="font-body text-base text-swsm-white/85 leading-relaxed">
        Réservez un créneau de 30 minutes avec l'équipe pour discuter de votre projet de partenariat.
      </p>
      <a
        href="https://calendly.com/swsm-racing-team"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-cta btn-cta-glass font-display font-bold text-sm uppercase tracking-caps-loose px-7 py-4 mt-4 self-start"
      >
        <span>Voir le calendrier</span>
        <span class="btn-cta-arrow">→</span>
      </a>
    </div>
  </div>
</section>

<script>
  document.getElementById("dp-dl-button")?.addEventListener("click", () => {
    if ((window as any).plausible) {
      (window as any).plausible("Download dossier sponsoring", { props: { source: "telechargement-section" } });
    }
  });
</script>
