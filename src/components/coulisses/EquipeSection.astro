---
// Section "Derrière les coulisses" — présentation de l'équipe technique en format magazine.
import { getCollection } from "astro:content";
import settings from "../../data/site-settings.json";
const s = settings.coulissesEquipe;

const equipe = (await getCollection("equipe")).sort(
  (a, b) => a.data.ordre - b.data.ordre,
);
---

<section class="equipe-section bg-swsm-white py-24 md:py-32 px-6 md:px-10 has-grain" aria-labelledby="equipe-title">
  <div class="max-w-[1240px] mx-auto">
    <!-- Header -->
    <header class="mb-16 md:mb-24 max-w-2xl">
      <p class="text-xs uppercase tracking-eyebrow font-display font-medium text-swsm-pink mb-5">
        {s.eyebrow}
      </p>
      <h2
        id="equipe-title"
        class="font-display font-bold text-swsm-black tracking-caps-tight leading-[1.05] text-3xl md:text-5xl mb-5"
        data-split-mask
      >
        {s.title}
      </h2>
      <p class="font-body text-base md:text-lg text-swsm-black/65 leading-relaxed">
        {s.subtitle}
      </p>
    </header>

    <!-- Membres en alternance -->
    <div class="flex flex-col gap-24 md:gap-32">
      {
        equipe.map((m, i) => {
          const reverse = i % 2 === 1;
          const numero = String(i + 1).padStart(2, "0");
          const initials = `${m.data.prenom[0] ?? ""}${m.data.nom[0] ?? ""}`.toUpperCase();
          return (
            <article
              class:list={[
                "equipe-member relative grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-14 items-center",
                "[&_.col-photo]:md:col-span-6",
                "[&_.col-info]:md:col-span-5",
              ]}
              data-equipe-member
            >
              {/* Numéro filigrane — au niveau de l'article, z-10 pour
                  déborder par-dessus la photo sans être caché */}
              <span
                aria-hidden="true"
                class:list={[
                  "absolute pointer-events-none select-none font-display font-bold leading-[0.8] tracking-caps-tight z-10",
                  "text-swsm-black/10 mix-blend-multiply",
                  "text-[7rem] md:text-[13rem]",
                  reverse
                    ? "-top-10 md:-top-14 right-2 md:right-8"
                    : "-top-10 md:-top-14 left-2 md:left-8",
                ]}
              >
                {numero}
              </span>

              {/* Photo */}
              <div
                class:list={[
                  "col-photo relative",
                  reverse ? "md:col-start-7" : "md:col-start-1",
                ]}
              >
                <div class="relative aspect-[3/4] overflow-hidden bg-swsm-black/5 rounded-sm">
                  {m.data.photo ? (
                    <img
                      src={m.data.photo}
                      alt={`${m.data.prenom} ${m.data.nom} — ${m.data.role}`}
                      class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out hover:scale-[1.03]"
                      loading="lazy"
                    />
                  ) : (
                    <div
                      class="absolute inset-0 flex items-center justify-center font-display font-bold text-swsm-black/15 tracking-caps-tight select-none text-7xl md:text-9xl"
                      aria-hidden="true"
                    >
                      {initials}
                    </div>
                  )}
                </div>
              </div>

              {/* Infos */}
              <div
                class:list={[
                  "col-info relative",
                  reverse ? "md:col-start-1 md:row-start-1 md:text-left" : "md:col-start-8",
                ]}
              >
                <p class="text-[10px] md:text-xs uppercase tracking-eyebrow font-display font-medium text-swsm-pink mb-3">
                  {m.data.role}
                </p>
                <h3 class="font-display font-bold text-swsm-black tracking-caps-tight leading-[1.05] text-3xl md:text-4xl lg:text-5xl mb-6">
                  {m.data.prenom} <span class="block md:inline">{m.data.nom}</span>
                </h3>

                {m.data.citation && (
                  <blockquote class="relative pl-6 md:pl-8 mb-6 md:mb-8 border-l-2 border-swsm-pink">
                    <p class="font-display font-medium italic text-lg md:text-xl text-swsm-black/85 leading-snug">
                      « {m.data.citation} »
                    </p>
                  </blockquote>
                )}

                <p class="font-body text-base text-swsm-black/70 leading-relaxed max-w-md">
                  {m.data.bio}
                </p>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  /* Reveal au scroll : fade + slight Y */
  [data-equipe-member] {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 800ms ease-out, transform 800ms ease-out;
  }
  [data-equipe-member].is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    [data-equipe-member] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  // Reveal au scroll via IntersectionObserver — vanilla, zéro GSAP, zéro framer-motion
  const members = document.querySelectorAll<HTMLElement>("[data-equipe-member]");
  if (members.length) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2, rootMargin: "0px 0px -10% 0px" },
    );
    members.forEach((el) => io.observe(el));
  }
</script>
