---
// Hero de /coulisses — version Halide topographic adaptée
// Photo couleur unique en canvas 3D rotated, mouse parallax, grain SVG.
// Métadata éditoriale aux 4 coins, titre "Les Coulisses." en mix-blend difference.
---

<section
  class="coul-hero relative w-full overflow-hidden"
  style="z-index:1;min-height:100vh;height:100vh;"
  aria-label="Magazine Coulisses SWSM Racing Team"
>
  <!-- Filtre SVG grain -->
  <svg style="position:absolute;width:0;height:0;pointer-events:none;" aria-hidden="true">
    <filter id="coul-hero-grain">
      <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" />
      <feColorMatrix type="saturate" values="0" />
    </filter>
  </svg>

  <!-- Grain overlay -->
  <div class="coul-hero-grain absolute inset-0 pointer-events-none" aria-hidden="true"></div>

  <!-- Interface grid (corners éditoriaux) -->
  <div class="coul-hero-grid">
    <div class="coul-hero-meta-tl">MAGAZINE</div>
    <div class="coul-hero-meta-tr">
      <div>SAISON 2026</div>
      <div>SWSM_RACING · ARCHIVE</div>
    </div>

    <h1 class="coul-hero-title font-display">
      Les Coulisses.
    </h1>

    <div class="coul-hero-meta-bottom">
      <div class="coul-hero-meta-bl">
        <p>[ ÉDITORIAL ]</p>
        <p>COMPTES RENDUS · PORTRAITS · ATELIER</p>
      </div>
      <div class="coul-hero-meta-br">
        <p>L'écurie au quotidien.</p>
      </div>
    </div>
  </div>

  <!-- 3D Canvas viewport -->
  <div class="coul-hero-viewport">
    <div class="coul-hero-canvas-3d" id="coul-hero-canvas">
      <div class="coul-hero-layer"></div>
      <div class="coul-hero-contours"></div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="coul-hero-scroll-hint" aria-hidden="true"></div>
</section>

<style>
  .coul-hero {
    background-color: #0a0a0a;
    color: #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .coul-hero-grain {
    filter: url(#coul-hero-grain);
    opacity: 0.13;
    z-index: 50;
  }

  .coul-hero-grid {
    position: absolute;
    inset: 0;
    padding: 6rem 2.5rem 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto 1fr auto;
    z-index: 20;
    pointer-events: none;
    color: #e0e0e0;
  }
  @media (min-width: 768px) {
    .coul-hero-grid { padding: 7rem 4rem 4rem; }
  }

  .coul-hero-meta-tl {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.08em;
    color: #EC2D7C;
  }
  .coul-hero-meta-tr {
    text-align: right;
    font-family: monospace;
    color: #EC2D7C;
    font-size: 0.7rem;
    line-height: 1.6;
    letter-spacing: 0.05em;
  }

  .coul-hero-title {
    grid-column: 1 / -1;
    align-self: center;
    font-size: clamp(2.5rem, 9vw, 9rem);
    line-height: 0.85;
    letter-spacing: -0.04em;
    mix-blend-mode: difference;
    color: #ffffff;
    margin: 0;
    font-weight: 700;
    pointer-events: none;
  }

  .coul-hero-meta-bottom {
    grid-column: 1 / -1;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
  }
  .coul-hero-meta-bl, .coul-hero-meta-br {
    font-family: monospace;
    font-size: 0.75rem;
    line-height: 1.6;
    letter-spacing: 0.05em;
  }
  .coul-hero-meta-bl p, .coul-hero-meta-br p { margin: 0; }
  .coul-hero-meta-br {
    color: #EC2D7C;
    text-align: right;
  }

  .coul-hero-viewport {
    perspective: 2000px;
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    z-index: 10;
  }

  .coul-hero-canvas-3d {
    position: relative;
    width: 900px;
    height: 560px;
    max-width: 92vw;
    max-height: 72vh;
    transform-style: preserve-3d;
    opacity: 0;
    transform: rotateX(90deg) rotateZ(0deg) scale(0.8);
    will-change: transform;
  }
  .coul-hero-canvas-3d.is-mounted {
    opacity: 1;
    transform: rotateX(55deg) rotateZ(-25deg) scale(1);
    transition: all 2.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .coul-hero-layer {
    position: absolute;
    inset: 0;
    border: 1px solid rgba(224, 224, 224, 0.15);
    background-image: url('/images/general/IMG_9442.JPG');
    background-size: cover;
    background-position: center;
    filter: contrast(1.05) saturate(1.1) brightness(0.95);
    transition: transform 0.5s ease;
    will-change: transform;
  }

  .coul-hero-contours {
    position: absolute;
    width: 200%;
    height: 200%;
    top: -50%;
    left: -50%;
    background-image: repeating-radial-gradient(circle at 50% 50%, transparent 0, transparent 40px, rgba(255,255,255,0.05) 41px, transparent 42px);
    transform: translateZ(120px);
    pointer-events: none;
  }

  .coul-hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, #e0e0e0, transparent);
    animation: coul-hero-flow 2s infinite ease-in-out;
    z-index: 25;
  }
  @keyframes coul-hero-flow {
    0%,100%{transform:scaleY(0);transform-origin:top}
    50%{transform:scaleY(1);transform-origin:top}
    51%{transform:scaleY(1);transform-origin:bottom}
  }

  @media (prefers-reduced-motion: reduce) {
    .coul-hero-canvas-3d {
      opacity: 1;
      transform: rotateX(55deg) rotateZ(-25deg) scale(1);
      transition: none;
    }
    .coul-hero-scroll-hint { animation: none; }
  }
</style>

<script>
  const canvas = document.getElementById("coul-hero-canvas") as HTMLElement | null;
  const layer = document.querySelector<HTMLElement>(".coul-hero-layer");

  if (canvas) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isMobile = window.matchMedia("(max-width: 768px)").matches;

    setTimeout(() => canvas.classList.add("is-mounted"), 300);

    if (!reduce && !isMobile) {
      let rafId = 0;
      let pendingX = 0;
      let pendingY = 0;

      const apply = () => {
        canvas.style.transform = `rotateX(${55 + pendingY / 2}deg) rotateZ(${-25 + pendingX / 2}deg)`;
        if (layer) {
          layer.style.transform = `translateZ(15px) translate(${pendingX * 0.2}px, ${pendingY * 0.2}px)`;
        }
        rafId = 0;
      };

      window.addEventListener("mousemove", (e: MouseEvent) => {
        pendingX = (window.innerWidth / 2 - e.pageX) / 25;
        pendingY = (window.innerHeight / 2 - e.pageY) / 25;
        if (!rafId) rafId = requestAnimationFrame(apply);
      }, { passive: true });
    }
  }
</script>
