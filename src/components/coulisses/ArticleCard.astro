---
import type { CollectionEntry } from "astro:content";

interface Props {
  article: CollectionEntry<"articles">;
}

const { article } = Astro.props;
const { id, data } = article;

const categoryLabel: Record<string, string> = {
  "compte-rendu": "Compte rendu",
  portrait: "Portrait",
  coulisses: "Coulisses",
  partenaire: "Partenaire",
  ecurie: "Vie d'écurie",
};

const dateFr = data.pubDate.toLocaleDateString("fr-FR", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<article
  class="coul-card group"
  data-article-cat={data.category}
>
  <a href={`/coulisses/${id}`} class="block">
    <div class="aspect-[4/3] overflow-hidden bg-swsm-black/5 rounded-sm relative">
      <img
        src={data.cover}
        alt={data.title}
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.06]"
        data-photo-reveal
        loading="lazy"
      />
    </div>
    <p class="text-xs uppercase tracking-eyebrow font-display font-medium text-swsm-pink mt-5">
      {categoryLabel[data.category]}
    </p>
    <h3 class="font-display font-bold text-swsm-black text-xl md:text-2xl mt-2 tracking-caps-tight leading-snug group-hover:text-swsm-pink transition-colors duration-300">
      {data.title}
    </h3>
    <p class="font-body text-sm text-swsm-black/55 mt-3">
      {dateFr}
    </p>
  </a>
</article>
