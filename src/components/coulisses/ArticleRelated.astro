---
import type { CollectionEntry } from "astro:content";
import ArticleCard from "./ArticleCard.astro";

interface Props {
  related: CollectionEntry<"articles">[];
}

const { related } = Astro.props;
---

{related.length > 0 && (
  <section class="art-related has-grain bg-swsm-white py-20 md:py-28 border-t border-swsm-black/10">
    <div class="max-w-[1240px] mx-auto px-6 md:px-10">
      <p class="text-xs uppercase tracking-eyebrow font-display font-medium text-swsm-pink mb-4">
        Articles liés
      </p>
      <h2
        class="font-display font-bold text-swsm-black tracking-caps-tight leading-[1.05] text-2xl md:text-4xl mb-12"
        data-split-mask
      >
        Continuez la lecture.
      </h2>
      <div class="grid md:grid-cols-3 gap-8 md:gap-10">
        {related.map((article) => <ArticleCard article={article} />)}
      </div>
    </div>
  </section>
)}
