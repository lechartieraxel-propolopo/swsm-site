---
// Section "teaser album" en fin de page Coulisses.
// Photos lues depuis album-photos.json (bento) — éditables via l'admin.
import ScrollMorphAlbum from "../ui/scroll-morph-album";
import settings from "../../data/site-settings.json";
import albumData from "../../data/album-photos.json";
const t = settings.coulissesAlbum;
const albumImages = albumData.bento.map((b) => b.url);
---

<ScrollMorphAlbum
  images={albumImages}
  introTitle={t.introTitle}
  introSubtitle={t.introSubtitle}
  arcTitle={t.arcTitle}
  arcSubtitle={t.arcSubtitle}
  ctaLabel={t.ctaLabel}
  ctaHref="/album"
  client:visible
/>
