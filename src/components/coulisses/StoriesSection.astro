---
// Section "Stories" coulisses — rangée d'avatars cliquables qui ouvrent une
// modale plein écran (format 9:16) avec autoplay des slides.
// Données lues depuis src/data/stories.json, éditables via l'admin.
import { StoriesRow, type StoryData } from "../ui/story";
import storiesData from "../../data/stories.json";
import settings from "../../data/site-settings.json";

const stories: StoryData[] = storiesData as StoryData[];
const s = settings.storiesCoulisses;
---

<section
  class="coul-stories relative bg-swsm-black text-swsm-white py-16 md:py-20 px-6 md:px-10"
  aria-label="Stories des coulisses"
>
  <div class="max-w-[1240px] mx-auto">
    <header class="mb-8 md:mb-10">
      <p class="text-xs uppercase tracking-[0.05em] font-display font-medium text-swsm-pink mb-3">
        {s.eyebrow}
      </p>
      <h2 class="font-display font-bold text-swsm-white tracking-[-0.01em] leading-[1.05] text-2xl md:text-3xl">
        {s.title}
      </h2>
    </header>

    <StoriesRow stories={stories} slideDuration={5000} client:visible />
  </div>
</section>
