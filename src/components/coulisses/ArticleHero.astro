---
import type { CollectionEntry } from "astro:content";

interface Props {
  article: CollectionEntry<"articles">;
  readingMinutes: number;
}

const { article, readingMinutes } = Astro.props;
const { data } = article;

const categoryLabel: Record<string, string> = {
  "compte-rendu": "Compte rendu",
  portrait: "Portrait",
  coulisses: "Coulisses",
  partenaire: "Partenaire",
  ecurie: "Vie d'écurie",
};

const dateFr = data.pubDate.toLocaleDateString("fr-FR", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<section
  class="art-hero relative w-full overflow-hidden bg-swsm-black"
  style="z-index:1;height:75vh;min-height:520px;"
  aria-label={data.title}
>
  <img
    src={data.cover}
    alt={data.title}
    class="art-hero-cover absolute inset-0 w-full h-full object-cover"
    loading="eager"
    fetchpriority="high"
  />
  <div
    class="absolute inset-0 z-10"
    style="background: linear-gradient(180deg, rgba(13,13,13,0.30) 0%, rgba(13,13,13,0.45) 50%, rgba(13,13,13,0.92) 100%);"
    aria-hidden="true"
  ></div>

  <div class="relative z-20 h-full max-w-[1240px] mx-auto px-6 md:px-10 flex flex-col justify-end pb-16 md:pb-24">
    <p class="art-hero-eyebrow text-xs uppercase tracking-eyebrow font-display font-medium text-swsm-pink mb-5">
      {categoryLabel[data.category]}
    </p>

    <h1
      class="art-hero-title font-display font-bold text-swsm-white tracking-caps-tight leading-[1.02] text-3xl md:text-5xl lg:text-7xl max-w-5xl mb-6"
      data-split-mask
    >
      {data.title}
    </h1>

    <p class="art-hero-meta font-body text-sm text-swsm-white/80 flex flex-wrap items-center gap-3">
      <span>SWSM Racing Team</span>
      <span class="opacity-50">·</span>
      <span>{dateFr}</span>
      <span class="opacity-50">·</span>
      <span>{readingMinutes} min de lecture</span>
    </p>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const eyebrow = document.querySelector<HTMLElement>(".art-hero-eyebrow");
  const meta = document.querySelector<HTMLElement>(".art-hero-meta");
  const cover = document.querySelector<HTMLElement>(".art-hero-cover");

  if (eyebrow && meta) {
    if (reduce) {
      gsap.set([eyebrow, meta], { opacity: 1, y: 0 });
    } else {
      gsap.set([eyebrow, meta], { opacity: 0, y: 20 });
      gsap.timeline()
        .to(eyebrow, { opacity: 1, y: 0, duration: 0.6, ease: "power2.out", delay: 0.3 })
        .to(meta, { opacity: 1, y: 0, duration: 0.6, ease: "power2.out" }, "+=0.5");
    }
  }
  if (cover && !reduce) {
    gsap.fromTo(cover, { scale: 1.08 }, { scale: 1, duration: 1.6, ease: "power2.out" });
  }
</script>
