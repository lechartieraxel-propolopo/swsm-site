---
// Hero "Album" — photo en fond + spiral animation overlay (mix-blend screen).
import { SpiralAnimation } from "../ui/spiral-animation";
---

<section
  class="album-hero relative w-full h-screen overflow-hidden bg-swsm-black"
  aria-label="Album photo SWSM Racing Team"
>
  <!-- Photo en fond -->
  <div
    class="absolute inset-0 z-0 bg-cover bg-center"
    style="background-image:url('/images/general/IMG_9442.JPG');"
    aria-hidden="true"
  ></div>

  <!-- Voile sombre pour lisibilité -->
  <div
    class="absolute inset-0 z-10 bg-gradient-to-b from-swsm-black/70 via-swsm-black/40 to-swsm-black/85"
    aria-hidden="true"
  ></div>

  <!-- Spiral animation par dessus (mix-blend-mode: screen géré dans le composant) -->
  <div class="absolute inset-0 z-20 pointer-events-none" aria-hidden="true">
    <SpiralAnimation client:load />
  </div>

  <!-- Contenu centré -->
  <div class="relative z-30 h-full flex items-center justify-center px-6 md:px-10">
    <div class="max-w-4xl text-center flex flex-col items-center gap-6">
      <p class="album-hero-eyebrow text-xs uppercase tracking-[0.05em] font-display font-medium text-swsm-pink">
        Album · Hors série
      </p>
      <h1
        class="album-hero-title font-display font-bold text-swsm-white tracking-[-0.01em] leading-[0.95] text-5xl md:text-7xl lg:text-8xl"
      >
        L'album SWSM.
      </h1>
      <p class="album-hero-sub font-body text-base md:text-lg text-swsm-white/80 max-w-xl leading-relaxed mt-2">
        Une saison capturée. Sans filtre, sans hiérarchie. Les images qui restent quand on range les caisses.
      </p>
      <div class="album-hero-scroll mt-12 flex flex-col items-center gap-2 text-swsm-white/60">
        <span class="text-[10px] uppercase tracking-[0.3em] font-display">Faire défiler</span>
        <span class="block w-px h-12 bg-gradient-to-b from-swsm-white/60 to-transparent"></span>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes albumHeroIn {
    from { opacity: 0; transform: translateY(25px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .album-hero-eyebrow,
  .album-hero-title,
  .album-hero-sub,
  .album-hero-scroll {
    opacity: 0;
    animation: albumHeroIn 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .album-hero-eyebrow { animation-delay: 0.4s; }
  .album-hero-title   { animation-delay: 0.6s; }
  .album-hero-sub     { animation-delay: 0.9s; }
  .album-hero-scroll  { animation-delay: 1.2s; }

  @media (prefers-reduced-motion: reduce) {
    .album-hero-eyebrow,
    .album-hero-title,
    .album-hero-sub,
    .album-hero-scroll {
      opacity: 1;
      animation: none;
    }
  }
</style>
