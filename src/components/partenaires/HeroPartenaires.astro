---
// Hero "Partenaires" — vidéo qui s'expanse au scroll, palette SWSM.
import { ScrollExpandHero } from "../ui/scroll-expansion-hero";
import settings from "../../data/site-settings.json";
const h = settings.partenairesHero;
---

<ScrollExpandHero
  client:load
  mediaType="video"
  mediaSrc="/videos/hero-partenaires.mp4"
  bgImageSrc="/images/general/IMG_9442.JPG"
  title={h.title}
  eyebrow={h.eyebrow}
  scrollToExpand={h.scrollLabel}
  textBlend={false}
>
  <div class="max-w-3xl mx-auto text-center text-swsm-white">
    <p class="text-xs uppercase tracking-[0.05em] font-display font-medium text-swsm-pink mb-5">
      {h.subEyebrow}
    </p>
    <h2 class="font-display font-bold tracking-[-0.01em] leading-[1.05] text-3xl md:text-5xl mb-6">
      {h.subTitle}
    </h2>
    <p class="font-body text-base md:text-lg text-swsm-white/75 leading-relaxed">
      {h.subText}
    </p>
  </div>
</ScrollExpandHero>
