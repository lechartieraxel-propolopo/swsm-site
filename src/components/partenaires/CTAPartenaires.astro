---
// CTA final de la page /partenaires
import settings from "../../data/site-settings.json";
const c = settings.partenairesCta;
---

<section
  class="part-cta relative bg-gradient-signature text-swsm-white min-h-screen flex items-center justify-center overflow-hidden py-24 md:py-32 px-6 md:px-10"
  style="z-index:6;box-shadow:0 -30px 60px -10px rgba(0,0,0,0.45);"
  aria-label="Devenir partenaire de SWSM Racing Team"
>
  <!-- Aurora subtile en bg pour la matière -->
  <div
    class="absolute inset-0 pointer-events-none opacity-40"
    aria-hidden="true"
    style="background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.15) 0%, transparent 50%), radial-gradient(circle at 70% 70%, rgba(255,255,255,0.10) 0%, transparent 50%);"
  ></div>

  <div class="relative z-10 max-w-[1240px] mx-auto text-center flex flex-col items-center gap-6">
    <p class="part-cta-eyebrow text-xs uppercase tracking-eyebrow font-display font-medium text-swsm-white/85">
      {c.eyebrow}
    </p>

    <h2
      class="part-cta-title font-display font-bold text-swsm-white uppercase tracking-caps-tight leading-[0.95] text-4xl md:text-6xl lg:text-7xl"
      data-split-mask
    >
      {c.titleLine1}<br />{c.titleLine2}
    </h2>

    <p class="part-cta-sub font-body text-base md:text-lg text-swsm-white/85 max-w-2xl mt-2">
      {c.subtitle}
    </p>

    <div class="part-cta-buttons mt-10 flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-4">
      <a
        href="/dossier-sponsoring.pdf"
        download
        class="btn-cta btn-cta-light font-display font-bold text-sm uppercase tracking-caps-loose px-8 py-4"
        data-plausible-event-name="Download dossier sponsoring"
      >
        <span>Télécharger le dossier</span>
        <span class="btn-cta-arrow">→</span>
      </a>
      <a
        href="/devenir-partenaire"
        class="btn-cta btn-cta-glass font-display font-bold text-sm uppercase tracking-caps-loose px-8 py-4"
      >
        <span>Prendre contact</span>
        <span class="btn-cta-arrow">→</span>
      </a>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const section = document.querySelector<HTMLElement>(".part-cta");
  const eyebrow = document.querySelector<HTMLElement>(".part-cta-eyebrow");
  const sub = document.querySelector<HTMLElement>(".part-cta-sub");
  const buttons = document.querySelector<HTMLElement>(".part-cta-buttons");

  if (section && eyebrow && sub && buttons) {
    if (reduce) {
      gsap.set([eyebrow, sub, buttons], { opacity: 1, y: 0 });
    } else {
      gsap.set([eyebrow, sub, buttons], { opacity: 0, y: 25 });
      gsap.timeline({
        scrollTrigger: { trigger: section, start: "top 75%", toggleActions: "play none none none" },
      })
        .to(eyebrow, { opacity: 1, y: 0, duration: 0.5, ease: "power2.out" })
        .to(sub, { opacity: 1, y: 0, duration: 0.6, ease: "power2.out" }, "-=0.2")
        .to(buttons, { opacity: 1, y: 0, duration: 0.6, ease: "power2.out" }, "-=0.3");
    }
  }
</script>
