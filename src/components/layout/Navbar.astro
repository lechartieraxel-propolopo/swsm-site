---
const links = [
  { href: "/", label: "Accueil" },
  { href: "/coulisses", label: "Coulisses" },
  { href: "/partenaires", label: "Partenaires" },
  { href: "/devenir-partenaire", label: "Devenir partenaire" },
];
---

<header
  id="swsm-navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-transform duration-300 ease-out bg-transparent"
  data-state="top"
>
  <div class="mx-auto max-w-[1240px] px-6 md:px-10">
    <nav class="flex items-center justify-between h-16 md:h-20 text-swsm-white">
      <a
        href="/"
        class="font-display font-bold text-lg md:text-xl tracking-caps-loose uppercase hover:opacity-80 transition-opacity"
        aria-label="SWSM Racing Team — Accueil"
      >
        SWSM
      </a>

      <ul class="hidden md:flex items-center gap-10">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class="link-underline font-body text-sm font-medium opacity-85 hover:opacity-100 transition-opacity"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <button
        id="swsm-burger"
        type="button"
        class="md:hidden inline-flex items-center justify-center w-10 h-10 -mr-2"
        aria-label="Ouvrir le menu"
        aria-controls="swsm-drawer"
        aria-expanded="false"
      >
        <span class="sr-only">Ouvrir le menu</span>
        <span class="relative block w-6 h-[2px] bg-current">
          <span class="absolute left-0 -top-2 block w-6 h-[2px] bg-current"></span>
          <span class="absolute left-0 top-2 block w-6 h-[2px] bg-current"></span>
        </span>
      </button>
    </nav>
  </div>

  <div
    id="swsm-drawer"
    class="md:hidden fixed inset-0 z-40 bg-swsm-black text-swsm-white opacity-0 pointer-events-none transition-opacity duration-300"
    aria-hidden="true"
  >
    <div class="flex items-center justify-between h-16 px-6">
      <a
        href="/"
        class="font-display font-bold text-lg tracking-caps-loose uppercase"
      >
        SWSM
      </a>
      <button
        id="swsm-burger-close"
        type="button"
        class="inline-flex items-center justify-center w-10 h-10 -mr-2"
        aria-label="Fermer le menu"
      >
        <span class="relative block w-6 h-6">
          <span class="absolute left-0 top-1/2 block w-6 h-[2px] bg-current rotate-45"></span>
          <span class="absolute left-0 top-1/2 block w-6 h-[2px] bg-current -rotate-45"></span>
        </span>
      </button>
    </div>
    <ul class="flex flex-col gap-8 px-6 mt-12">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="font-display font-bold text-3xl tracking-caps-tight"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<style>
  /* Quand la page a un hero clair (body.light-navbar) et qu'on est en haut (data-state="top"),
     la navbar utilise du texte foncé pour rester lisible sur le fond blanc.
     Une fois scrolled, le backdrop sombre prend le dessus → texte blanc retrouvé. */
  body.light-navbar #swsm-navbar[data-state="top"] nav {
    color: #0D0D0D;
  }
</style>

<script>
  const navbar = document.getElementById("swsm-navbar");
  const burger = document.getElementById("swsm-burger");
  const drawer = document.getElementById("swsm-drawer");
  const burgerClose = document.getElementById("swsm-burger-close");

  if (navbar) {
    let lastY = window.scrollY;
    let ticking = false;
    const SCROLL_THRESHOLD = 8;
    const HIDE_AFTER = 200; // hide-on-scroll uniquement au-delà
    const FADE_RANGE = 100; // 0→100px de scroll : opacité du fond 0→0.95

    // Backdrop séparé pour interpoler l'opacité sans toucher au texte
    const backdrop = document.createElement("div");
    backdrop.style.cssText =
      "position:absolute;inset:0;background:rgba(13,13,13,0.95);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);opacity:0;transition:opacity 80ms linear;pointer-events:none;z-index:-1;";
    navbar.style.position = navbar.style.position || "fixed";
    navbar.appendChild(backdrop);

    const onScroll = () => {
      const y = window.scrollY;
      const delta = y - lastY;

      // Progressive opacity du fond : 0 → 1 entre 0 et FADE_RANGE
      const bgOpacity = Math.min(y / FADE_RANGE, 1);
      backdrop.style.opacity = String(bgOpacity);

      navbar.dataset.state = y <= 24 ? "top" : "scrolled";

      // Hide-on-scroll : seulement après 200px (laisse vivre le hero)
      if (y > HIDE_AFTER && Math.abs(delta) > SCROLL_THRESHOLD) {
        navbar.style.transform = delta > 0 ? "translateY(-100%)" : "translateY(0)";
      } else if (y <= HIDE_AFTER) {
        navbar.style.transform = "translateY(0)";
      }

      lastY = y;
      ticking = false;
    };

    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          window.requestAnimationFrame(onScroll);
          ticking = true;
        }
      },
      { passive: true },
    );
  }

  const openDrawer = () => {
    if (!drawer || !burger) return;
    drawer.classList.remove("opacity-0", "pointer-events-none");
    drawer.classList.add("opacity-100");
    drawer.setAttribute("aria-hidden", "false");
    burger.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  };

  const closeDrawer = () => {
    if (!drawer || !burger) return;
    drawer.classList.add("opacity-0", "pointer-events-none");
    drawer.classList.remove("opacity-100");
    drawer.setAttribute("aria-hidden", "true");
    burger.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  };

  burger?.addEventListener("click", openDrawer);
  burgerClose?.addEventListener("click", closeDrawer);

  drawer?.querySelectorAll("a").forEach((a) => a.addEventListener("click", closeDrawer));

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeDrawer();
  });
</script>
