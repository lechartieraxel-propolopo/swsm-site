---
const links = [
  { href: "/", label: "Accueil" },
  { href: "/coulisses", label: "Coulisses" },
  { href: "/partenaires", label: "Partenaires" },
  { href: "/devenir-partenaire", label: "Devenir partenaire" },
];
---

<header
  id="swsm-navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-transform duration-300 ease-out bg-transparent"
  data-state="top"
>
  <div class="mx-auto max-w-[1240px] px-5 md:px-10">
    <nav class="flex items-center justify-between h-16 md:h-20 text-swsm-white">
      <a
        href="/"
        class="font-display font-bold text-lg md:text-xl tracking-caps-loose uppercase hover:opacity-80 transition-opacity"
        aria-label="SWSM Racing Team — Accueil"
      >
        SWSM
      </a>

      <!-- Nav desktop -->
      <ul class="hidden md:flex items-center gap-10">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class="link-underline font-body text-sm font-medium opacity-85 hover:opacity-100 transition-opacity"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Burger mobile : pill glassmorphism, visible sur n'importe quel fond -->
      <button
        id="swsm-burger"
        type="button"
        class="swsm-burger md:hidden inline-flex items-center justify-center w-11 h-11 rounded-full bg-white/10 hover:bg-white/20 backdrop-blur-md border border-white/15 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-swsm-pink"
        aria-label="Ouvrir le menu"
        aria-controls="swsm-drawer"
        aria-expanded="false"
      >
        <span class="sr-only">Ouvrir le menu</span>
        <span class="relative block w-5 h-[2px] bg-current rounded">
          <span class="absolute left-0 -top-[6px] block w-5 h-[2px] bg-current rounded"></span>
          <span class="absolute left-0 top-[6px] block w-3.5 h-[2px] bg-current rounded transition-all"></span>
        </span>
      </button>
    </nav>
  </div>
</header>

<!-- Drawer mobile — SIBLING du header (pas enfant) pour que le fixed
     se positionne par rapport au viewport, pas au header transformé. -->
<div
  id="swsm-drawer"
  class="swsm-drawer md:hidden text-swsm-white"
  data-open="false"
  aria-hidden="true"
>
  <!-- Halo rose/violet en arrière-plan -->
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style="background: radial-gradient(ellipse at 80% 10%, rgba(236,45,124,0.20) 0%, transparent 55%), radial-gradient(ellipse at 20% 90%, rgba(91,33,182,0.20) 0%, transparent 55%);"
  ></div>

  <div class="relative flex items-center justify-between h-16 px-5">
    <a
      href="/"
      class="font-display font-bold text-lg tracking-caps-loose uppercase"
    >
      SWSM
    </a>
    <button
      id="swsm-burger-close"
      type="button"
      class="inline-flex items-center justify-center w-11 h-11 rounded-full bg-white/10 hover:bg-white/20 backdrop-blur-md border border-white/15 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-swsm-pink"
      aria-label="Fermer le menu"
    >
      <span class="relative block w-5 h-5">
        <span class="absolute left-0 top-1/2 block w-5 h-[2px] bg-current rotate-45 rounded"></span>
        <span class="absolute left-0 top-1/2 block w-5 h-[2px] bg-current -rotate-45 rounded"></span>
      </span>
    </button>
  </div>

  <!-- Eyebrow + nav links -->
  <div class="relative px-6 mt-12">
    <p class="text-[10px] uppercase tracking-[0.25em] font-display font-medium text-swsm-pink mb-8">
      Menu
    </p>
    <ul class="flex flex-col gap-7">
      {
        links.map((link, i) => (
          <li class="swsm-drawer-item" style={`transition-delay:${i * 60 + 100}ms`}>
            <a
              href={link.href}
              class="font-display font-bold text-3xl sm:text-4xl tracking-[-0.01em] inline-flex items-baseline gap-3 hover:text-swsm-pink transition-colors"
            >
              <span class="text-[10px] uppercase tracking-[0.2em] font-medium text-swsm-white/40 mt-2">
                0{i + 1}
              </span>
              <span>{link.label}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <!-- Footer drawer : ancré tout en bas en safe-area, séparé visuellement -->
  <div
    class="absolute left-6 right-6 bottom-0 pb-[max(env(safe-area-inset-bottom),1.5rem)] flex items-center justify-between gap-4 border-t border-white/10 pt-5"
  >
    <a
      href="/devenir-partenaire#contact"
      class="font-display text-xs uppercase tracking-[0.18em] font-medium text-swsm-white/70 hover:text-swsm-pink transition-colors"
    >
      Contact →
    </a>
    <span class="font-body text-[10px] uppercase tracking-[0.15em] text-swsm-white/35">
      SWSM · 2026
    </span>
  </div>
</div>

<style>
  /* Sur les pages à hero clair (body.light-navbar) en haut de page → texte foncé. */
  body.light-navbar #swsm-navbar[data-state="top"] nav {
    color: #0D0D0D;
  }
  /* Burger sur fond clair : fond noir translucide pour contraste */
  body.light-navbar #swsm-navbar[data-state="top"] .swsm-burger {
    background-color: rgba(13, 13, 13, 0.06);
    border-color: rgba(13, 13, 13, 0.12);
  }
  body.light-navbar #swsm-navbar[data-state="top"] .swsm-burger:hover {
    background-color: rgba(13, 13, 13, 0.12);
  }

  /* ─── Drawer mobile : OPACITÉ TOTALE, jamais transparent ─── */
  .swsm-drawer {
    position: fixed;
    inset: 0;
    background-color: #0D0D0D; /* swsm-black 100% opaque */
    z-index: 9999;
    visibility: hidden;
    opacity: 0;
    transition: opacity 280ms ease-out, visibility 0s linear 280ms;
    pointer-events: none;
  }
  .swsm-drawer[data-open="true"] {
    visibility: visible;
    opacity: 1;
    pointer-events: auto;
    transition: opacity 280ms ease-out, visibility 0s linear 0s;
  }
  @media (min-width: 768px) {
    .swsm-drawer { display: none; }
  }

  /* Drawer : items qui slident depuis la gauche au open */
  .swsm-drawer-item {
    opacity: 0;
    transform: translateX(-12px);
    transition: opacity 500ms cubic-bezier(0.22, 1, 0.36, 1), transform 500ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .swsm-drawer[data-open="true"] .swsm-drawer-item {
    opacity: 1;
    transform: translateX(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .swsm-drawer-item { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  const navbar = document.getElementById("swsm-navbar");
  const burger = document.getElementById("swsm-burger");
  const drawer = document.getElementById("swsm-drawer");
  const burgerClose = document.getElementById("swsm-burger-close");

  if (navbar) {
    let lastY = window.scrollY;
    let ticking = false;
    const SCROLL_THRESHOLD = 8;
    const HIDE_AFTER = 200;
    const FADE_RANGE = 100;

    const backdrop = document.createElement("div");
    backdrop.style.cssText =
      "position:absolute;inset:0;background:rgba(13,13,13,0.95);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);opacity:0;transition:opacity 80ms linear;pointer-events:none;z-index:-1;";
    navbar.style.position = navbar.style.position || "fixed";
    navbar.appendChild(backdrop);

    const onScroll = () => {
      const y = window.scrollY;
      const delta = y - lastY;
      const bgOpacity = Math.min(y / FADE_RANGE, 1);
      backdrop.style.opacity = String(bgOpacity);
      navbar.dataset.state = y <= 24 ? "top" : "scrolled";

      if (y > HIDE_AFTER && Math.abs(delta) > SCROLL_THRESHOLD) {
        navbar.style.transform = delta > 0 ? "translateY(-100%)" : "translateY(0)";
      } else if (y <= HIDE_AFTER) {
        navbar.style.transform = "translateY(0)";
      }

      lastY = y;
      ticking = false;
    };

    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          window.requestAnimationFrame(onScroll);
          ticking = true;
        }
      },
      { passive: true },
    );
  }

  const openDrawer = () => {
    if (!drawer || !burger) return;
    drawer.setAttribute("data-open", "true");
    drawer.setAttribute("aria-hidden", "false");
    burger.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  };

  const closeDrawer = () => {
    if (!drawer || !burger) return;
    drawer.setAttribute("data-open", "false");
    drawer.setAttribute("aria-hidden", "true");
    burger.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  };

  burger?.addEventListener("click", openDrawer);
  burgerClose?.addEventListener("click", closeDrawer);

  drawer?.querySelectorAll("a").forEach((a) => a.addEventListener("click", closeDrawer));

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeDrawer();
  });
</script>
