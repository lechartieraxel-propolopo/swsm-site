---
// Section A — Hero — version crossfade + Ken Burns
// Texte et photos lus depuis src/data/site-settings.json, éditables via l'admin.
import settings from "../../data/site-settings.json";
import saison from "../../data/saison.json";

const hero = settings.hero;
const photos = (hero.photos ?? []).slice(0, 3);
while (photos.length < 3) photos.push(photos[0] ?? "/images/hero/hero-1.jpg");

// Prochaine manche : sélection auto basée sur la date du jour
const today = new Date();
today.setHours(0, 0, 0, 0);
const upcoming = saison.manches
  .filter((m: any) => new Date(m.date) >= today)
  .sort((a: any, b: any) => new Date(a.date).valueOf() - new Date(b.date).valueOf());
const nextRace = upcoming[0] as any;

const formatWeekend = (start: string, end?: string) => {
  const ds = new Date(start);
  if (!end) {
    return ds.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" });
  }
  const de = new Date(end);
  const sameMonth =
    ds.getMonth() === de.getMonth() && ds.getFullYear() === de.getFullYear();
  if (sameMonth) {
    return `${ds.getDate()}—${de.getDate()} ${de.toLocaleDateString("fr-FR", { month: "long", year: "numeric" })}`;
  }
  return `${ds.toLocaleDateString("fr-FR", { day: "numeric", month: "long" })} → ${de.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}`;
};
---

<section
  class="hero relative min-h-screen w-full flex items-center justify-center overflow-hidden bg-swsm-black"
  style="z-index:1;"
  aria-label="Présentation SWSM Racing Team"
>
  <!-- ─── CALQUE 0 — Slideshow 3 photos ─── -->
  <div class="hero-photo-layer absolute inset-0 z-0" aria-hidden="true">
    <div class="hero-frame hero-frame-1 absolute inset-0 overflow-hidden">
      <img src={photos[0]} alt="" class="hero-photo absolute inset-0 w-full h-full object-cover" loading="eager" fetchpriority="high" />
    </div>
    <div class="hero-frame hero-frame-2 absolute inset-0 overflow-hidden">
      <img src={photos[1]} alt="" class="hero-photo absolute inset-0 w-full h-full object-cover" loading="eager" />
    </div>
    <div class="hero-frame hero-frame-3 absolute inset-0 overflow-hidden">
      <img src={photos[2]} alt="" class="hero-photo absolute inset-0 w-full h-full object-cover" loading="eager" />
    </div>
  </div>

  <!-- ─── CALQUE 5 — Grain photographique ─── -->
  <div class="hero-grain absolute inset-0 z-[5] pointer-events-none" aria-hidden="true"></div>

  <!-- ─── CALQUE 15 — Light flare diagonal ─── -->
  <div class="hero-flare absolute inset-0 z-[15] pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="flare-beam"></div>
  </div>

  <!-- ─── CALQUE 18 — Particules ─── -->
  <div class="hero-particles absolute inset-0 z-[18] pointer-events-none overflow-hidden" aria-hidden="true">
    {Array.from({ length: 30 }).map((_, i) => (
      <span class={`particle particle-${i % 6}`} style={`--i:${i};`}></span>
    ))}
  </div>

  <!-- ─── CALQUE 20 — Overlay lisibilité ─── -->
  <div class="absolute inset-0 z-20 bg-black/30" aria-hidden="true"></div>

  <!-- ─── CALQUE 30 — Texte aligné bas-gauche (collé au bord, pas centré) ─── -->
  <div class="relative z-30 w-full h-screen px-6 md:px-12 lg:px-16 flex flex-col justify-end pb-24 md:pb-28">
    <p class="hero-eyebrow text-xs uppercase tracking-[0.25em] font-display font-medium text-swsm-pink mb-5 inline-flex items-center gap-3">
      <span class="block w-6 h-px bg-swsm-pink" aria-hidden="true"></span>
      <span>{hero.eyebrow}</span>
    </p>

    <h1
      class="hero-title font-display font-bold text-swsm-white tracking-[-0.02em] leading-[0.95] text-5xl md:text-7xl lg:text-8xl mb-8 md:mb-10 max-w-5xl"
      data-split-hero
    >
      {
        // Split le titre par phrase (séparateur ". ") et met chaque
        // phrase sur sa propre ligne via display:block.
        hero.title.split(/\. /).map((part: string, i: number, arr: string[]) => (
          <span class="block">
            {part}{i < arr.length - 1 ? "." : ""}
          </span>
        ))
      }
    </h1>

    <p class="hero-sub font-body text-sm md:text-base text-swsm-white/90 max-w-xl">
      {hero.subtitle}
    </p>
  </div>

  <!-- ─── BAS DE HERO : Prochaine manche (gauche) + Scroll (droite) ─── -->
  <div class="absolute left-0 right-0 bottom-0 z-30 px-6 md:px-12 lg:px-16 pb-6 md:pb-8 flex items-end justify-between gap-6">
    {nextRace && (
      <div class="hero-next-race flex flex-col gap-1 text-swsm-white">
        <p class="text-[10px] md:text-xs uppercase tracking-[0.25em] font-display font-medium text-swsm-pink inline-flex items-center gap-2">
          <span class="inline-block w-2 h-2 rounded-full bg-swsm-pink animate-[hero-pulse_2s_ease-in-out_infinite]" aria-hidden="true"></span>
          Prochaine manche
        </p>
        <p class="text-xs md:text-sm font-body text-swsm-white/85">
          <span class="font-display font-medium">{nextRace.lieu}</span>
          <span class="text-swsm-white/55"> · {formatWeekend(nextRace.date, nextRace.date_fin)}</span>
        </p>
      </div>
    )}
    <span class="text-[10px] md:text-xs uppercase tracking-[0.3em] font-display font-medium text-swsm-white/55 shrink-0">
      Scroll
    </span>
  </div>
</section>

<style>
  /* ═══ CALQUE 0 — Photos + Ken Burns ═══════════════════════════════ */
  .hero-frame {
    opacity: 0;
    animation: hero-frame-fade 12s infinite ease-in-out;
    will-change: opacity;
  }
  .hero-frame-1 { opacity: 1; animation-delay: 0s; }
  .hero-frame-2 { animation-delay: -8s; }
  .hero-frame-3 { animation-delay: -4s; }

  @keyframes hero-frame-fade {
    0%, 25%   { opacity: 1; }
    33%, 92%  { opacity: 0; }
    100%      { opacity: 1; }
  }

  .hero-photo {
    transform-origin: center center;
    animation: hero-photo-zoom 12s infinite ease-in-out;
    will-change: transform;
  }
  .hero-frame-1 .hero-photo { animation-delay: 0s; }
  .hero-frame-2 .hero-photo { animation-delay: -8s; }
  .hero-frame-3 .hero-photo { animation-delay: -4s; }

  @keyframes hero-photo-zoom {
    0%   { transform: scale(1); }
    25%  { transform: scale(1.05); }
    33%  { transform: scale(1.06); }
    34%  { transform: scale(1); }
    100% { transform: scale(1); }
  }

  /* ═══ CALQUE 5 — Grain photographique ═════════════════════════════ */
  .hero-grain {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='240' height='240'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
    background-size: 240px 240px;
    opacity: 0.08;
    mix-blend-mode: overlay;
  }

  /* ═══ CALQUE 15 — Light flare diagonal ═════════════════════════════ */
  .flare-beam {
    position: absolute;
    top: -50%;
    left: -30%;
    width: 30%;
    height: 200%;
    background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.06) 30%, rgba(255, 255, 255, 0.18) 50%, rgba(255, 255, 255, 0.06) 70%, transparent 100%);
    transform: rotate(20deg) translateX(-100%);
    animation: hero-flare-sweep 11s ease-in-out infinite;
    will-change: transform;
    mix-blend-mode: screen;
    filter: blur(30px);
  }
  @keyframes hero-flare-sweep {
    0%, 30%   { transform: rotate(20deg) translateX(-100%); opacity: 0; }
    35%       { opacity: 1; }
    65%       { opacity: 1; }
    70%, 100% { transform: rotate(20deg) translateX(500%); opacity: 0; }
  }

  /* ═══ CALQUE 18 — Particules ══════════════════════════════════════ */
  .particle {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.4);
    box-shadow: 0 0 6px rgba(255, 255, 255, 0.3);
    --i: 0;
    top: calc((var(--i) * 37%) - floor((var(--i) * 37%) / 100%) * 100%);
    left: calc((var(--i) * 53%) - floor((var(--i) * 53%) / 100%) * 100%);
    animation: particle-float 12s ease-in-out infinite;
    animation-delay: calc(var(--i) * -0.4s);
    will-change: transform, opacity;
  }
  .particle-0 { animation-duration: 14s; opacity: 0.3; }
  .particle-1 { animation-duration: 10s; opacity: 0.4; width: 3px; height: 3px; }
  .particle-2 { animation-duration: 16s; opacity: 0.25; width: 5px; height: 5px; }
  .particle-3 { animation-duration: 12s; opacity: 0.35; }
  .particle-4 { animation-duration: 9s;  opacity: 0.3; width: 3px; height: 3px; }
  .particle-5 { animation-duration: 13s; opacity: 0.4; width: 4px; height: 4px; }

  @keyframes particle-float {
    0%   { transform: translate(0, 0); opacity: 0; }
    10%  { opacity: 0.4; }
    50%  { transform: translate(20px, -40px); }
    90%  { opacity: 0.4; }
    100% { transform: translate(-10px, -80px); opacity: 0; }
  }

  /* ═══ Scroll indicator : souris stylisée ══════════════════════════ */
  .hero-mouse {
    width: 22px;
    height: 36px;
    border: 1.5px solid currentColor;
    border-radius: 14px;
    position: relative;
    opacity: 0.7;
  }
  .hero-mouse-wheel {
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 6px;
    background: currentColor;
    border-radius: 2px;
    animation: mouse-scroll 1.8s ease-in-out infinite;
  }
  @keyframes mouse-scroll {
    0%   { transform: translate(-50%, 0); opacity: 1; }
    50%  { transform: translate(-50%, 12px); opacity: 0.3; }
    100% { transform: translate(-50%, 0); opacity: 1; }
  }

  /* ═══ Point rose pulsant pour Prochaine manche ════════════════════ */
  @keyframes hero-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(236, 45, 124, 0.55); }
    50%      { box-shadow: 0 0 0 8px rgba(236, 45, 124, 0); }
  }

  /* ═══ Reduced motion ══════════════════════════════════════════════ */
  @media (prefers-reduced-motion: reduce) {
    .hero-frame, .hero-photo, .flare-beam, .particle, .hero-mouse-wheel,
    .hero-next-race [class*="animate-"] {
      animation: none !important;
    }
    .hero-frame-1 { opacity: 1; }
    .hero-frame-2, .hero-frame-3 { opacity: 0; }
    .hero-photo { transform: scale(1); }
    .particle { opacity: 0.3; }
  }
</style>
