---
// Bento Gallery — porté du composant 21st.dev "interactive image bento gallery"
// en Astro + GSAP. Drag-to-scroll horizontal, bento grid, modale au clic.
//
// Position dans la home : entre Hero (sticky) et Manifeste (stacking reveal).

const items = [
  {
    id: "img-1",
    src: "/images/hero/hero-1.jpg",
    title: "L'action en piste",
    desc: "Trois pilotes engagés en Championnat de France.",
    span: "md:col-span-2 md:row-span-2", // gros 2×2
  },
  {
    id: "img-2",
    src: "/images/general/IMG_9408.JPG",
    title: "Paddock",
    desc: "Le week-end de course.",
    span: "md:row-span-1",
  },
  {
    id: "img-3",
    src: "/images/general/IMG_9421.JPG",
    title: "Équipement",
    desc: "Préparation matériel.",
    span: "md:row-span-1",
  },
  {
    id: "img-4",
    src: "/images/hero/hero-2.jpg",
    title: "Approche du virage",
    desc: "Lecture de la piste.",
    span: "md:row-span-2", // tall 1×2
  },
  {
    id: "img-5",
    src: "/images/general/IMG_9456.JPG",
    title: "Détail moto",
    desc: "Mécanique en course.",
    span: "md:row-span-1",
  },
  {
    id: "img-6",
    src: "/images/hero/hero-3.jpg",
    title: "L'écurie",
    desc: "Trois pilotes, une équipe.",
    span: "md:col-span-2 md:row-span-1", // wide 2×1
  },
  {
    id: "img-7",
    src: "/images/general/IMG_9442.JPG",
    title: "Sortie de virage",
    desc: "Reprise des gaz.",
    span: "md:row-span-1",
  },
  {
    id: "img-8",
    src: "/images/general/IMG_9430.JPG",
    title: "Engagement",
    desc: "Maximum d'angle.",
    span: "md:row-span-1",
  },
];
---

<section
  class="bento relative bg-swsm-black text-swsm-white py-20 md:py-28 overflow-hidden"
  style="z-index:1;"
  aria-label="Galerie photos SWSM Racing Team"
>
  <!-- Halo subtil rose-violet en bg pour signature SWSM -->
  <div
    class="absolute inset-0 pointer-events-none opacity-25"
    aria-hidden="true"
    style="background: radial-gradient(ellipse at 30% 30%, rgba(236,45,124,0.18) 0%, transparent 55%), radial-gradient(ellipse at 70% 70%, rgba(91,33,182,0.18) 0%, transparent 55%);"
  ></div>

  <!-- Header centré -->
  <header class="relative z-10 max-w-3xl mx-auto px-6 md:px-10 text-center mb-12 md:mb-16">
    <p class="bento-eyebrow text-xs uppercase tracking-eyebrow font-display font-medium text-swsm-pink mb-5">
      L'écurie en images
    </p>
    <h2
      class="bento-title font-display font-bold text-swsm-white tracking-caps-tight leading-[1.05] text-3xl md:text-5xl mb-5"
      data-split-mask
    >
      Au plus près de l'écurie.
    </h2>
    <p class="bento-desc font-body text-base md:text-lg text-swsm-white/70">
      Coulisses, paddock, piste. Glissez horizontalement pour parcourir, cliquez pour agrandir.
    </p>
  </header>

  <!-- Drag-scroll container (horizontal) -->
  <div
    class="bento-scroll relative w-full overflow-x-auto overflow-y-hidden cursor-grab"
    style="scroll-behavior:smooth;-webkit-overflow-scrolling:touch;"
  >
    <div
      class="bento-grid grid grid-flow-col auto-cols-[15rem] md:auto-cols-[18rem] grid-rows-2 gap-4 md:gap-5 px-6 md:px-10 pb-2"
      style="grid-template-rows: 12rem 12rem;"
    >
      {items.map((item) => (
        <button
          type="button"
          class={`bento-card group relative overflow-hidden rounded-xl border border-swsm-white/10 bg-swsm-black/40 transition-shadow duration-300 hover:border-swsm-pink/40 hover:shadow-[0_20px_40px_-15px_rgba(236,45,124,0.35)] ${item.span}`}
          data-bento-card
          data-img-src={item.src}
          data-img-title={item.title}
          data-img-desc={item.desc}
          aria-label={`Voir ${item.title}`}
        >
          <img
            src={item.src}
            alt={item.title}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.06]"
            loading="lazy"
            draggable="false"
          />
          <!-- Overlay dégradé qui apparaît au hover -->
          <div
            class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/85 via-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            aria-hidden="true"
          ></div>
          <!-- Texte qui se révèle au hover -->
          <div class="pointer-events-none absolute bottom-0 left-0 right-0 p-4 md:p-5 translate-y-3 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 z-10">
            <p class="text-[10px] uppercase tracking-eyebrow font-display font-medium text-swsm-pink mb-1">
              SWSM_racing
            </p>
            <h3 class="font-display font-bold text-swsm-white text-base md:text-lg tracking-caps-tight leading-tight">
              {item.title}
            </h3>
            <p class="font-body text-xs md:text-sm text-swsm-white/80 mt-1 leading-snug">
              {item.desc}
            </p>
          </div>
        </button>
      ))}
    </div>
  </div>

  <!-- Hint scroll horizontal -->
  <div class="relative z-10 max-w-3xl mx-auto px-6 md:px-10 mt-8 text-center">
    <p class="font-body text-xs text-swsm-white/40 uppercase tracking-eyebrow font-display">
      ← Glissez ou utilisez la molette →
    </p>
  </div>

  <!-- Modale (cachée par défaut) -->
  <div
    id="bento-modal"
    class="fixed inset-0 z-[100] flex items-center justify-center pointer-events-none opacity-0 transition-opacity duration-300"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
  >
    <button
      type="button"
      class="absolute inset-0 bg-black/85 backdrop-blur-md cursor-pointer"
      data-bento-close
      aria-label="Fermer"
    ></button>

    <div class="relative z-10 max-w-5xl w-full mx-auto p-4 md:p-8 pointer-events-auto">
      <img
        id="bento-modal-img"
        src=""
        alt=""
        class="block w-full h-auto max-h-[85vh] object-contain rounded-lg shadow-2xl mx-auto"
      />
      <div class="text-center mt-6 max-w-2xl mx-auto">
        <h3 id="bento-modal-title" class="font-display font-bold text-swsm-white text-xl md:text-2xl tracking-caps-tight"></h3>
        <p id="bento-modal-desc" class="font-body text-sm md:text-base text-swsm-white/70 mt-2"></p>
      </div>
    </div>

    <button
      type="button"
      class="absolute top-4 right-4 md:top-6 md:right-6 z-20 w-11 h-11 inline-flex items-center justify-center rounded-full bg-swsm-white/10 hover:bg-swsm-pink hover:scale-110 backdrop-blur transition-all border border-swsm-white/20 text-swsm-white"
      data-bento-close
      aria-label="Fermer la modale"
    >
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6L6 18"></path>
        <path d="M6 6l12 12"></path>
      </svg>
    </button>
  </div>
</section>

<style>
  /* Cache la scrollbar visuelle, garde le scroll fonctionnel */
  .bento-scroll::-webkit-scrollbar {
    height: 0;
    background: transparent;
  }
  .bento-scroll {
    scrollbar-width: none;
  }

  /* Pendant le drag, désactive transitions photos pour un mouvement fluide */
  .bento-scroll.is-dragging {
    cursor: grabbing;
  }
  .bento-scroll.is-dragging .bento-card img {
    transition: none;
  }
  .bento-scroll.is-dragging * {
    pointer-events: none;
    user-select: none;
  }

  .bento-card {
    height: 100%;
    min-height: 12rem;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // ─── Animation d'entrée ──────────────────────────────────────────
  const section = document.querySelector<HTMLElement>(".bento");
  const eyebrow = document.querySelector<HTMLElement>(".bento-eyebrow");
  const desc = document.querySelector<HTMLElement>(".bento-desc");
  const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-bento-card]"));

  if (section && eyebrow && desc && cards.length) {
    if (reduce) {
      gsap.set([eyebrow, desc, ...cards], { opacity: 1, y: 0, scale: 1 });
    } else {
      gsap.set([eyebrow, desc], { opacity: 0, y: 20 });
      gsap.set(cards, { opacity: 0, y: 30, scale: 0.95 });
      gsap.timeline({
        scrollTrigger: { trigger: section, start: "top 75%", toggleActions: "play none none none" },
      })
        .to(eyebrow, { opacity: 1, y: 0, duration: 0.5, ease: "power2.out" })
        .to(desc, { opacity: 1, y: 0, duration: 0.6, ease: "power2.out" }, "-=0.2")
        .to(cards, { opacity: 1, y: 0, scale: 1, duration: 0.6, ease: "power2.out", stagger: 0.08 }, "-=0.3");
    }
  }

  // ─── Drag-to-scroll horizontal ───────────────────────────────────
  const scroller = document.querySelector<HTMLElement>(".bento-scroll");
  if (scroller) {
    let isDown = false;
    let startX = 0;
    let scrollLeftStart = 0;
    let hasDragged = false;

    scroller.addEventListener("mousedown", (e: MouseEvent) => {
      isDown = true;
      hasDragged = false;
      startX = e.pageX;
      scrollLeftStart = scroller.scrollLeft;
      scroller.classList.add("is-dragging");
    });

    scroller.addEventListener("mouseleave", () => {
      isDown = false;
      scroller.classList.remove("is-dragging");
    });

    scroller.addEventListener("mouseup", () => {
      isDown = false;
      scroller.classList.remove("is-dragging");
    });

    scroller.addEventListener("mousemove", (e: MouseEvent) => {
      if (!isDown) return;
      e.preventDefault();
      const dx = e.pageX - startX;
      if (Math.abs(dx) > 5) hasDragged = true;
      scroller.scrollLeft = scrollLeftStart - dx * 1.2;
    });

    // Empêche le clic carte d'ouvrir la modale après un drag
    scroller.addEventListener("click", (e) => {
      if (hasDragged) {
        e.preventDefault();
        e.stopPropagation();
      }
    }, true);

    // Permet aussi le scroll vertical de molette → scroll horizontal
    scroller.addEventListener("wheel", (e: WheelEvent) => {
      if (Math.abs(e.deltaY) > Math.abs(e.deltaX)) {
        e.preventDefault();
        scroller.scrollLeft += e.deltaY;
      }
    }, { passive: false });
  }

  // ─── Modale ──────────────────────────────────────────────────────
  const modal = document.getElementById("bento-modal");
  const modalImg = document.getElementById("bento-modal-img") as HTMLImageElement | null;
  const modalTitle = document.getElementById("bento-modal-title");
  const modalDesc = document.getElementById("bento-modal-desc");
  const closers = Array.from(document.querySelectorAll<HTMLElement>("[data-bento-close]"));

  const openModal = (src: string, title: string, desc: string) => {
    if (!modal || !modalImg || !modalTitle || !modalDesc) return;
    modalImg.src = src;
    modalImg.alt = title;
    modalTitle.textContent = title;
    modalDesc.textContent = desc;
    modal.classList.remove("opacity-0", "pointer-events-none");
    modal.classList.add("opacity-100", "pointer-events-auto");
    modal.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  };

  const closeModal = () => {
    if (!modal) return;
    modal.classList.add("opacity-0", "pointer-events-none");
    modal.classList.remove("opacity-100", "pointer-events-auto");
    modal.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  };

  cards.forEach((card) => {
    card.addEventListener("click", () => {
      const src = card.dataset.imgSrc || "";
      const title = card.dataset.imgTitle || "";
      const desc = card.dataset.imgDesc || "";
      openModal(src, title, desc);
    });
  });

  closers.forEach((c) => c.addEventListener("click", closeModal));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });
</script>
