---
// Stories — preview accueil. Données lues depuis src/data/stories.json,
// éditables via l'admin (App Gestion).
import { StoriesRow, type StoryData } from "../ui/story";
import storiesData from "../../data/stories.json";

const stories: StoryData[] = storiesData as StoryData[];

---

<section
  class="home-stories relative bg-swsm-black text-swsm-white py-20 md:py-28 px-6 md:px-10"
  aria-label="Stories de l'écurie"
>
  <div class="max-w-[1240px] mx-auto">
    <header class="mb-10 md:mb-12 max-w-2xl">
      <p class="text-xs uppercase tracking-[0.05em] font-display font-medium text-swsm-pink mb-4">
        L'instant
      </p>
      <h2 class="font-display font-bold text-swsm-white tracking-[-0.01em] leading-[1.05] text-3xl md:text-5xl mb-4">
        Une saison, en quelques tap.
      </h2>
      <p class="font-body text-base md:text-lg text-swsm-white/70 leading-relaxed">
        Quatre fenêtres sur l'écurie : atelier, pré-grille, course, coulisses.
      </p>
    </header>

    <StoriesRow stories={stories} slideDuration={5000} client:visible />
  </div>
</section>
