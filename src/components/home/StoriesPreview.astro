---
// Stories — preview accueil. Même composant que /coulisses mais avec un
// header adapté au contexte home (intro plus accrocheuse).
import { StoriesRow, type StoryData } from "../ui/story";

const stories: StoryData[] = [
  {
    id: "atelier",
    avatarLabel: "Atelier",
    avatarImage: "/images/general/IMG_9351.JPG",
    slides: [
      {
        img: "/images/general/IMG_9351.JPG",
        eyebrow: "Préparation",
        title: "Le silence avant le départ.",
        caption: "On vérifie deux fois. Pas de place à l'à-peu-près.",
      },
      {
        img: "/images/general/IMG_9379.JPG",
        eyebrow: "Stand",
        title: "Cinq minutes pour ajuster.",
        caption: "Une butée, un cran de plus, on retourne en piste.",
      },
      {
        img: "/images/general/IMG_9403.JPG",
        eyebrow: "Mécanique",
        title: "Tout dépend de ce moment-là.",
        caption: "Les heures de prépa qu'on ne voit pas, mais qui tiennent tout.",
      },
      {
        img: "/images/general/IMG_9421.JPG",
        eyebrow: "Équipement",
        title: "Tout ce qu'il faut. Rien de plus.",
        caption: "L'inventaire d'une journée de course.",
      },
    ],
  },
  {
    id: "pregrille",
    avatarLabel: "Pré-grille",
    avatarImage: "/images/general/IMG_9408.JPG",
    slides: [
      {
        img: "/images/general/IMG_9408.JPG",
        eyebrow: "Pré-grille",
        title: "Le casque vissé.",
        caption: "Le rythme cardiaque qui monte tranquille.",
      },
      {
        img: "/images/general/IMG_9440.JPG",
        eyebrow: "Concentration",
        title: "Le regard.",
        caption: "Les visualisations du tour avant le départ.",
      },
      {
        img: "/images/general/IMG_9416.JPG",
        eyebrow: "Détail",
        title: "Les sliders qui ont vu du bitume.",
        caption: "Chaque trace, une histoire.",
      },
    ],
  },
  {
    id: "course",
    avatarLabel: "Course",
    avatarImage: "/images/general/IMG_9442.JPG",
    slides: [
      {
        img: "/images/general/IMG_9442.JPG",
        eyebrow: "En course",
        title: "Pleine charge.",
        caption: "Le moteur chante, le corps suit.",
      },
      {
        img: "/images/general/IMG_9412.JPG",
        eyebrow: "Ligne droite",
        title: "On regarde devant.",
        caption: "Jamais derrière.",
      },
      {
        img: "/images/general/IMG_9430.JPG",
        eyebrow: "Tracé",
        title: "Connu par cœur.",
        caption: "Et appris à chaque tour.",
      },
      {
        img: "/images/general/IMG_9446.JPG",
        eyebrow: "Drift",
        title: "Quand l'arrière sort un peu.",
        caption: "On contre, on relance.",
      },
    ],
  },
  {
    id: "coulisses",
    avatarLabel: "Coulisses",
    avatarImage: "/images/general/IMG_9451.JPG",
    slides: [
      {
        img: "/images/general/IMG_9399.JPG",
        eyebrow: "Paddock",
        title: "Discussion technique.",
        caption: "Les data parlent, mais le ressenti aussi.",
      },
      {
        img: "/images/general/IMG_9451.JPG",
        eyebrow: "Photographe",
        title: "L'image fait partie du sport.",
        caption: "On joue le jeu, l'instant se capture.",
      },
      {
        img: "/images/general/IMG_9459.JPG",
        eyebrow: "Soir",
        title: "La fatigue qui s'installe.",
        caption: "Mais le sourire reste.",
      },
    ],
  },
];
---

<section
  class="home-stories relative bg-swsm-black text-swsm-white py-20 md:py-28 px-6 md:px-10"
  aria-label="Stories de l'écurie"
>
  <div class="max-w-[1240px] mx-auto">
    <header class="mb-10 md:mb-12 max-w-2xl">
      <p class="text-xs uppercase tracking-[0.05em] font-display font-medium text-swsm-pink mb-4">
        L'instant
      </p>
      <h2 class="font-display font-bold text-swsm-white tracking-[-0.01em] leading-[1.05] text-3xl md:text-5xl mb-4">
        Une saison, en quelques tap.
      </h2>
      <p class="font-body text-base md:text-lg text-swsm-white/70 leading-relaxed">
        Quatre fenêtres sur l'écurie : atelier, pré-grille, course, coulisses.
      </p>
    </header>

    <StoriesRow stories={stories} slideDuration={5000} client:visible />
  </div>
</section>
