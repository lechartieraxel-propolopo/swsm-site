---
import { ZoomParallax, type ManifestoContent } from "../ui/zoom-parallax";

const images = [
  { src: "/images/hero/hero-1.jpg",      alt: "SWSM Racing Team — image principale" },
  { src: "/images/hero/hero-2.jpg",      alt: "SWSM Racing Team — paddock" },
  { src: "/images/hero/hero-3.jpg",      alt: "SWSM Racing Team — action" },
  { src: "/images/general/IMG_9442.JPG", alt: "SWSM Racing Team — moto" },
  { src: "/images/general/IMG_9421.JPG", alt: "SWSM Racing Team — équipement" },
  { src: "/images/general/IMG_9430.JPG", alt: "SWSM Racing Team — piste" },
  { src: "/images/general/IMG_9456.JPG", alt: "SWSM Racing Team — détail" },
];

const manifesto: ManifestoContent = {
  eyebrow: "Notre engagement",
  title1: "Investir dans une structure.",
  title2: "Pas seulement sponsoriser un pilote.",
  ctaLabel: "En savoir plus",
  ctaHref: "/partenaires",
};
---

<section class="zp-wrapper relative bg-swsm-white" style="z-index:1;">
  <ZoomParallax images={images} manifesto={manifesto} client:load />
</section>
