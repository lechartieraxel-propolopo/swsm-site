---
import { ZoomParallax, type ManifestoContent } from "../ui/zoom-parallax";
import settings from "../../data/site-settings.json";

const z = (settings as { zoomParallax?: { images?: string[]; manifesto?: ManifestoContent } }).zoomParallax ?? {
  images: ["/images/hero/hero-1.jpg", "/images/hero/hero-2.jpg", "/images/hero/hero-3.jpg", "/images/general/IMG_9442.JPG", "/images/general/IMG_9421.JPG", "/images/general/IMG_9430.JPG", "/images/general/IMG_9456.JPG"],
  manifesto: { eyebrow: "Notre engagement", title1: "Investir dans une structure.", title2: "Pas seulement sponsoriser un pilote.", ctaLabel: "En savoir plus", ctaHref: "/partenaires" },
};

const images = (z.images ?? []).map((src: string, i: number) => ({
  src,
  alt: `SWSM Racing Team — image ${i + 1}`,
}));

const manifesto: ManifestoContent = z.manifesto ?? {
  eyebrow: "Notre engagement",
  title1: "Investir dans une structure.",
  title2: "Pas seulement sponsoriser un pilote.",
  ctaLabel: "En savoir plus",
  ctaHref: "/partenaires",
};
---

<section class="zp-wrapper relative bg-swsm-white" style="z-index:1;">
  <ZoomParallax images={images} manifesto={manifesto} client:load />
</section>
