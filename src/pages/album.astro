---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroAlbum from "../components/album/HeroAlbum.astro";
import InteractiveImageBentoGallery, { type ImageItem } from "../components/ui/bento-gallery";
import { FeatureCarousel, type Feature } from "../components/ui/feature-carousel";
import { MomentsCarousel } from "../components/album/MomentsCarousel";
import { SmoothScrollHero } from "../components/ui/smooth-scroll-hero";
import settings from "../data/site-settings.json";
import albumData from "../data/album-photos.json";

const ALBUM = settings;
const chapitres: Feature[] = albumData.chapitres as Feature[];
const moments = albumData.moments;
const albumItems: ImageItem[] = albumData.bento as ImageItem[];
const revealImage = albumData.revealImage;
---

<BaseLayout
  title="Album"
  description="L'album photo de SWSM Racing Team. Coulisses, courses, instants. Une saison vue de près."
>
  <!-- 1. HERO immersif : photo + spiral animation overlay -->
  <HeroAlbum />

  <!-- 2. FEATURE CAROUSEL : la saison en 5 chapitres -->
  <section
    class="album-chapters relative bg-swsm-black text-swsm-white py-24 md:py-32 px-6 md:px-10"
    style="z-index:2;box-shadow:0 -40px 80px -10px rgba(0,0,0,0.6);"
    aria-label="La saison en cinq chapitres"
  >
    <div class="max-w-[1240px] mx-auto">
      <header class="max-w-2xl mb-12 md:mb-16">
        <p class="text-xs uppercase tracking-[0.05em] font-display font-medium text-swsm-pink mb-5">
          {ALBUM.albumChapters.eyebrow}
        </p>
        <h2
          class="font-display font-bold tracking-[-0.01em] leading-[1.05] text-3xl md:text-5xl mb-4"
          data-split-mask
        >
          {ALBUM.albumChapters.title}
        </h2>
        <p class="font-body text-base md:text-lg text-swsm-white/70 leading-relaxed">
          {ALBUM.albumChapters.subtitle}
        </p>
      </header>

      <FeatureCarousel features={chapitres} client:visible />
    </div>
  </section>

  <!-- 3. SMOOTH SCROLL HERO : révélation parallax au scroll -->
  <section class="album-reveal relative" aria-label="Photo emblématique">
    <SmoothScrollHero
      scrollHeight={1200}
      desktopImage={revealImage}
      mobileImage={revealImage}
      initialClipPercentage={20}
      finalClipPercentage={80}
      client:visible
    >
      <div class="text-center px-6 max-w-3xl pointer-events-none">
        <p class="text-xs uppercase tracking-[0.05em] font-display font-medium text-swsm-pink mb-5 drop-shadow-lg">
          {ALBUM.albumReveal.eyebrow}
        </p>
        <h2 class="font-display font-bold text-swsm-white tracking-[-0.01em] leading-[1.05] text-4xl md:text-6xl drop-shadow-2xl">
          {ALBUM.albumReveal.titleLine1}<br/>{ALBUM.albumReveal.titleLine2}
        </h2>
      </div>
    </SmoothScrollHero>
  </section>

  <!-- 4. PROGRESSIVE CAROUSEL : moments forts en autoplay -->
  <section
    class="album-moments relative bg-swsm-white text-swsm-black py-24 md:py-32 px-6 md:px-10 has-grain"
    aria-label="Moments forts"
  >
    <div class="max-w-[1240px] mx-auto">
      <header class="max-w-2xl mb-12 md:mb-16">
        <p class="text-xs uppercase tracking-[0.05em] font-display font-medium text-swsm-pink mb-5">
          {ALBUM.albumMoments.eyebrow}
        </p>
        <h2
          class="font-display font-bold text-swsm-black tracking-[-0.01em] leading-[1.05] text-3xl md:text-5xl mb-4"
          data-split-mask
        >
          {ALBUM.albumMoments.title}
        </h2>
        <p class="font-body text-base md:text-lg text-swsm-black/70 leading-relaxed">
          {ALBUM.albumMoments.subtitle}
        </p>
      </header>

      <div class="relative max-w-[1100px] mx-auto">
        <MomentsCarousel moments={moments} client:visible />
      </div>
    </div>
  </section>

  <!-- 5. BENTO GALLERY : l'album complet drag horizontal -->
  <section
    class="album-bento bg-swsm-white text-swsm-black border-t border-swsm-black/10"
    aria-label="L'album complet"
  >
    <div class="max-w-[1240px] mx-auto px-6 md:px-10 pt-24 md:pt-32 pb-4">
      <header class="max-w-2xl">
        <p class="text-xs uppercase tracking-[0.05em] font-display font-medium text-swsm-pink mb-5">
          {ALBUM.albumBento.eyebrow}
        </p>
        <h2
          class="font-display font-bold text-swsm-black tracking-[-0.01em] leading-[1.05] text-3xl md:text-5xl mb-4"
          data-split-mask
        >
          {ALBUM.albumBento.title}
        </h2>
      </header>
    </div>
    <InteractiveImageBentoGallery
      imageItems={albumItems}
      title=""
      description="Vingt instants captés sur une saison. Glissez pour parcourir, cliquez sur une image pour la voir en grand format avec son contexte."
      client:visible
    />
  </section>

  <!-- 6. OUTRO -->
  <section class="album-outro bg-swsm-black text-swsm-white py-24 md:py-32 px-6 md:px-10">
    <div class="max-w-[800px] mx-auto text-center">
      <p class="text-[10px] md:text-xs uppercase tracking-[0.05em] font-display font-medium text-swsm-pink mb-6">
        {ALBUM.albumOutro.eyebrow}
      </p>
      <h2 class="font-display font-bold tracking-[-0.01em] leading-[1.05] text-2xl md:text-4xl mb-6">
        {ALBUM.albumOutro.title}
      </h2>
      <p class="font-body text-sm md:text-base text-swsm-white/70 leading-relaxed mb-10">
        {ALBUM.albumOutro.subtitle}
      </p>
      <a
        href="/coulisses"
        class="btn-cta btn-cta-light font-display font-bold text-sm uppercase tracking-[0.05em] px-7 py-4"
      >
        <span>{ALBUM.albumOutro.ctaLabel}</span>
        <span class="btn-cta-arrow">→</span>
      </a>
    </div>
  </section>
</BaseLayout>
