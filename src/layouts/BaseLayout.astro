---
import BaseHead from "../components/layout/BaseHead.astro";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";

interface Props {
  title: string;
  description: string;
  image?: string;
  /** True si la page a un hero clair → la navbar utilise du texte foncé en haut */
  lightNavbar?: boolean;
}

const { title, description, image, lightNavbar = false } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body class:list={["font-body bg-swsm-white text-swsm-black antialiased", lightNavbar && "light-navbar"]}>
    <!-- Filter SVG global pour effet liquid glass sur les boutons -->
    <svg class="absolute" style="width:0;height:0;position:absolute;pointer-events:none;" aria-hidden="true">
      <defs>
        <filter id="liquid-glass-filter" x="0%" y="0%" width="100%" height="100%" color-interpolation-filters="sRGB">
          <feTurbulence type="fractalNoise" baseFrequency="0.05 0.05" numOctaves="1" seed="1" result="turbulence" />
          <feGaussianBlur in="turbulence" stdDeviation="2" result="blurredNoise" />
          <feDisplacementMap in="SourceGraphic" in2="blurredNoise" scale="70" xChannelSelector="R" yChannelSelector="B" result="displaced" />
          <feGaussianBlur in="displaced" stdDeviation="4" result="finalBlur" />
          <feComposite in="finalBlur" in2="finalBlur" operator="over" />
        </filter>
      </defs>
    </svg>

    <Navbar />

    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<script>
  import "../scripts/animations";
</script>
