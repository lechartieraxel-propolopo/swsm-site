---
import BaseLayout from "./BaseLayout.astro";
import ArticleHero from "../components/coulisses/ArticleHero.astro";
import ArticleShare from "../components/coulisses/ArticleShare.astro";
import ArticleRelated from "../components/coulisses/ArticleRelated.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  article: CollectionEntry<"articles">;
  related: CollectionEntry<"articles">[];
  readingMinutes: number;
  url: string;
}

const { article, related, readingMinutes, url } = Astro.props;
const { data } = article;
---

<BaseLayout
  title={data.title}
  description={data.description}
  image={data.cover}
>
  <ArticleHero article={article} readingMinutes={readingMinutes} />

  <article class="art-body bg-swsm-white py-16 md:py-24" style="z-index:2;">
    <div class="max-w-3xl mx-auto px-6 md:px-10">
      <div class="art-prose font-body text-swsm-black/85">
        <slot />
      </div>

      <ArticleShare url={url} title={data.title} />
    </div>
  </article>

  <ArticleRelated related={related} />

  <section class="art-end-cta relative bg-gradient-signature text-swsm-white py-20 md:py-28 px-6 md:px-10 overflow-hidden" style="z-index:3;">
    <div class="absolute inset-0 pointer-events-none opacity-40" aria-hidden="true"
      style="background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.15) 0%, transparent 50%), radial-gradient(circle at 70% 70%, rgba(255,255,255,0.10) 0%, transparent 50%);"></div>
    <div class="relative z-10 max-w-3xl mx-auto text-center flex flex-col items-center gap-6">
      <p class="art-end-eyebrow text-xs uppercase tracking-eyebrow font-display font-medium text-swsm-white/85">
        Vous avez aimé cet article ?
      </p>
      <h2 class="art-end-title font-display font-bold text-swsm-white tracking-caps-tight leading-[1.05] text-3xl md:text-5xl" data-split-mask>
        Découvrez l'écurie.
      </h2>
      <div class="mt-4 flex flex-col sm:flex-row gap-4">
        <a href="/partenaires" class="btn-cta btn-cta-glass font-display font-bold text-sm uppercase tracking-caps-loose px-8 py-4">
          <span>Voir les partenaires</span><span class="btn-cta-arrow">→</span>
        </a>
        <a href="/devenir-partenaire" class="btn-cta btn-cta-light font-display font-bold text-sm uppercase tracking-caps-loose px-8 py-4">
          <span>Devenir partenaire</span><span class="btn-cta-arrow">→</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* Typographie soignée du corps d'article */
  .art-prose { font-size: 1.0625rem; line-height: 1.75; }
  @media (min-width: 768px) {
    .art-prose { font-size: 1.125rem; line-height: 1.75; }
  }
  .art-prose p { margin-bottom: 1.4em; }
  .art-prose h2 {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--swsm-black);
    font-size: 1.875rem;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-top: 3rem;
    margin-bottom: 1rem;
  }
  @media (min-width: 768px) { .art-prose h2 { font-size: 2.25rem; } }
  .art-prose h3 {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--swsm-black);
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .art-prose a {
    color: #EC2D7C;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color 0.2s;
  }
  .art-prose a:hover { color: #5B21B6; }
  .art-prose strong { color: var(--swsm-black); font-weight: 600; }
  .art-prose em { font-style: italic; }
  .art-prose blockquote {
    border-left: 3px solid #EC2D7C;
    padding-left: 1.5rem;
    font-style: italic;
    color: rgba(13, 13, 13, 0.75);
    margin: 2rem 0;
  }
  .art-prose ul {
    list-style: none;
    padding-left: 0;
    margin: 1.5rem 0;
  }
  .art-prose ul li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .art-prose ul li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: #EC2D7C;
    font-weight: 700;
  }
  .art-prose img {
    width: 100vw;
    max-width: calc(100% + 4rem);
    margin-left: -2rem;
    margin-right: -2rem;
    border-radius: 4px;
    margin-top: 2.5rem;
    margin-bottom: 2.5rem;
  }
  @media (min-width: 768px) {
    .art-prose img { margin-left: -4rem; margin-right: -4rem; max-width: calc(100% + 8rem); }
  }
</style>
